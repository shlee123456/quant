# Trading Bot Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# ===============================================
# Cryptocurrency Brokers (CCXT)
# ===============================================

# Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Upbit
UPBIT_API_KEY=your_upbit_api_key_here
UPBIT_API_SECRET=your_upbit_api_secret_here

# Coinbase
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# ===============================================
# Korea Investment Securities (Stocks)
# ===============================================
# 한국투자증권 API 사용을 위한 설정
#
# 1. 한국투자증권 홈페이지에서 API 신청
#    - 모의투자: https://apiportal.koreainvestment.com/intro (모의투자 계좌 발급)
#    - 실전투자: https://apiportal.koreainvestment.com/intro (실전투자 계좌 연결)
#
# 2. APPKEY와 APPSECRET 발급받기
#    - [API신청] 메뉴에서 신규 앱 등록
#    - 발급된 APPKEY, APPSECRET을 아래에 입력
#
# 3. 계좌번호 확인
#    - 형식: 12345678-01 (계좌번호-계좌상품코드)
#    - 모의투자 계좌번호는 API 포털에서 확인
#
# 4. 모의투자 vs 실전 계정
#    - KIS_MOCK=true: 모의투자 계정 (가상 자금, 실제 거래 없음)
#    - KIS_MOCK=false: 실전 계정 (실제 자금, 실제 거래 발생)
#    - 주의: 실전 계정 사용 시 실제 거래가 발생하므로 신중하게 설정할 것!
#
# 참고: 모의투자와 실전투자는 각각 다른 APPKEY/APPSECRET 필요

# App credentials
KIS_APPKEY=your_korea_investment_appkey_here
KIS_APPSECRET=your_korea_investment_appsecret_here

# Account number (format: 12345678-01)
KIS_ACCOUNT=your_account_number_here

# User ID (optional - defaults to KIS_ACCOUNT if not set)
# KIS_USER_ID=@12345678

# Mock trading mode (true=모의투자, false=실전)
KIS_MOCK=true

# ===============================================
# Application Settings
# ===============================================

# Initial capital for backtesting
INITIAL_CAPITAL=10000.0

# Position size (0.0 to 1.0, e.g., 0.95 = 95% of capital)
POSITION_SIZE=0.95

# Commission rate (e.g., 0.001 = 0.1%)
COMMISSION=0.001

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Timezone
TIMEZONE=Asia/Seoul

# ===============================================
# Dashboard Settings (Streamlit)
# ===============================================

# Server port (default: 8501)
STREAMLIT_SERVER_PORT=8501

# Server address (0.0.0.0 for Docker, localhost for local)
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Disable usage stats collection
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# Enable development mode (auto-reload on file changes)
STREAMLIT_SERVER_RUN_ON_SAVE=false

# ===============================================
# Database Settings (Optional - for future use)
# ===============================================

# DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot
# REDIS_URL=redis://localhost:6379/0

# ===============================================
# Monitoring & Alerting (Phase 2)
# ===============================================
#
# Slack 알림 서비스 설정 가이드:
#
# 1. Slack Webhook (텍스트 메시지용):
#    - https://api.slack.com/messaging/webhooks 접속
#    - 새 앱 생성 또는 기존 앱 선택
#    - "Incoming Webhooks" 활성화
#    - Webhook URL 복사하여 아래에 입력
#
# 2. Slack Bot Token (파일 업로드용):
#    - https://api.slack.com/apps 접속
#    - 앱 선택 → "OAuth & Permissions" 메뉴
#    - Bot Token Scopes 추가:
#      - files:write (파일 업로드 권한)
#      - chat:write (메시지 전송 권한)
#      - channels:read (채널 목록 조회 - 선택)
#    - "Install to Workspace" 클릭
#    - Bot User OAuth Token 복사 (xoxb-로 시작)
#
# 3. Slack 채널 ID 확인:
#    - Slack에서 채널 우클릭 → "View channel details"
#    - 하단에 "Channel ID" 표시 (예: C0123456789)
#    - 또는 `python examples/debug_slack_channels.py` 실행하여 확인
#
# 4. Bot을 채널에 초대:
#    - Slack 채널에서 `/invite @bot_name` 실행
#    - 또는 채널 설정 → Integrations → Add apps

# Slack Webhook URL (텍스트 메시지 전송용)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack Bot Token (파일 업로드용 - xoxb-로 시작)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack Channel ID (메시지/파일 전송 채널 - C로 시작, # 기호 없음)
SLACK_CHANNEL=C0123456789

# Email notifications (SMTP)
# Gmail 사용 시: 2단계 인증 활성화 후 앱 비밀번호 생성 필요
# https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_TO=recipient1@example.com,recipient2@example.com

# Future: Telegram Bot
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===============================================
# LLM Server (Phase 3 - Signal Filter / Regime Judgment)
# ===============================================
# llm-server FastAPI 게이트웨이 주소 (인터페이스 정의서 참조)
# llm-server가 프롬프트/모델 라우팅을 담당, trading-server는 구조화 데이터만 전달
#
# 엔드포인트:
#   POST /v1/signal-filter   - VBT/전략 시그널 검증 (Qwen2.5-7B-AWQ, 5초)
#   POST /v1/regime-judgment  - 통계 레짐에 LLM 판단 보강 (Qwen2.5-14B-AWQ, 15초)
#   POST /v1/sentiment        - 뉴스 센티먼트 분석 (FinBERT, Phase 4)
#   GET  /v1/health           - 서비스 상태 확인

# LLM 서버 기본 URL (FastAPI 게이트웨이)
LLM_BASE_URL=http://your-llm-server-ip:8080

# LLM 연동 활성화 (false로 비활성화 시 모든 LLM 호출 스킵, fail-open)
LLM_ENABLED=true

# 개별 엔드포인트 타임아웃 (초, 선택 - 기본값 사용 권장)
# LLM_SIGNAL_TIMEOUT=5
# LLM_REGIME_TIMEOUT=15
# LLM_SENTIMENT_TIMEOUT=30

# 하위 호환: vLLM 직접 호출 URL (마이그레이션 완료 후 제거 예정)
# LLM_SIGNAL_URL=http://your-llm-server-ip:8001/v1/chat/completions
# LLM_REGIME_URL=http://your-llm-server-ip:8000/v1/chat/completions

# ===============================================
# Market Analysis (Daily Report to Notion)
# ===============================================
# 일일 시장 분석 활성화 (true/false)
MARKET_ANALYSIS_ENABLED=true
# 분석 대상 종목 (쉼표 구분, 기본: 시가총액 Top 10)
MARKET_ANALYSIS_SYMBOLS=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA,AVGO,LLY,WMT
# 노션 페이지 ID (시장 데이터 분석 페이지)
NOTION_MARKET_ANALYSIS_PAGE_ID=30dd62f0-dffd-80a6-b624-e5a061ed26a9
# 뉴스 수집 활성화 (true/false, 기본: true)
NEWS_COLLECTION_ENABLED=true
# 종목당 최대 뉴스 수
NEWS_MAX_PER_SYMBOL=5

# ===============================================
# Performance Tuning (Optional)
# ===============================================

# Number of worker processes
# WORKERS=4

# Max concurrent requests
# MAX_CONCURRENT_REQUESTS=100
