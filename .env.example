# Trading Bot Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# ===============================================
# Cryptocurrency Brokers (CCXT)
# ===============================================

# Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Upbit
UPBIT_API_KEY=your_upbit_api_key_here
UPBIT_API_SECRET=your_upbit_api_secret_here

# Coinbase
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# ===============================================
# Korea Investment Securities (Stocks)
# ===============================================
# 한국투자증권 API 사용을 위한 설정
#
# 1. 한국투자증권 홈페이지에서 API 신청
#    - 모의투자: https://apiportal.koreainvestment.com/intro (모의투자 계좌 발급)
#    - 실전투자: https://apiportal.koreainvestment.com/intro (실전투자 계좌 연결)
#
# 2. APPKEY와 APPSECRET 발급받기
#    - [API신청] 메뉴에서 신규 앱 등록
#    - 발급된 APPKEY, APPSECRET을 아래에 입력
#
# 3. 계좌번호 확인
#    - 형식: 12345678-01 (계좌번호-계좌상품코드)
#    - 모의투자 계좌번호는 API 포털에서 확인
#
# 4. 모의투자 vs 실전 계정
#    - KIS_MOCK=true: 모의투자 계정 (가상 자금, 실제 거래 없음)
#    - KIS_MOCK=false: 실전 계정 (실제 자금, 실제 거래 발생)
#    - 주의: 실전 계정 사용 시 실제 거래가 발생하므로 신중하게 설정할 것!
#
# 참고: 모의투자와 실전투자는 각각 다른 APPKEY/APPSECRET 필요

# App credentials
KIS_APPKEY=your_korea_investment_appkey_here
KIS_APPSECRET=your_korea_investment_appsecret_here

# Account number (format: 12345678-01)
KIS_ACCOUNT=your_account_number_here

# Mock trading mode (true=모의투자, false=실전)
KIS_MOCK=true

# ===============================================
# Application Settings
# ===============================================

# Initial capital for backtesting
INITIAL_CAPITAL=10000.0

# Position size (0.0 to 1.0, e.g., 0.95 = 95% of capital)
POSITION_SIZE=0.95

# Commission rate (e.g., 0.001 = 0.1%)
COMMISSION=0.001

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Timezone
TIMEZONE=Asia/Seoul

# ===============================================
# Dashboard Settings (Streamlit)
# ===============================================

# Server port (default: 8501)
STREAMLIT_SERVER_PORT=8501

# Server address (0.0.0.0 for Docker, localhost for local)
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Disable usage stats collection
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# Enable development mode (auto-reload on file changes)
STREAMLIT_SERVER_RUN_ON_SAVE=false

# ===============================================
# Database Settings (Optional - for future use)
# ===============================================

# DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot
# REDIS_URL=redis://localhost:6379/0

# ===============================================
# Monitoring & Alerting (Optional - for future use)
# ===============================================

# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===============================================
# Performance Tuning (Optional)
# ===============================================

# Number of worker processes
# WORKERS=4

# Max concurrent requests
# MAX_CONCURRENT_REQUESTS=100
