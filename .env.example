# Trading Bot Environment Variables
# cp .env.example .env 후 값을 채워주세요. .env는 Git에 커밋하지 마세요.

# ===========================
# 공통 설정
# ===========================

INITIAL_CAPITAL=10000.0
POSITION_SIZE=0.95
COMMISSION=0.001
LOG_LEVEL=INFO
TIMEZONE=Asia/Seoul

# ===========================
# 국내 시장 (한국)
# ===========================

# --- 한국투자증권 KIS API (https://apiportal.koreainvestment.com/) ---
KIS_APPKEY=your_kis_appkey_here
KIS_APPSECRET=your_kis_appsecret_here
KIS_ACCOUNT=12345678-01
KIS_MOCK=true

# --- BOK 한국은행 API (https://ecos.bok.or.kr/api/) ---
BOK_API_KEY=your_bok_api_key_here

# --- 국내 시장 분석 ---
KR_SCHEDULER_ENABLED=true
KR_MARKET_ANALYSIS_SYMBOLS=005930,000660,005380,035420,035720,006400,373220,005490,105560,207940

# --- Notion API (Internal Integration Token) ---
NOTION_API_TOKEN=ntn_your_notion_integration_token_here

# --- 국내 노션 리포트 ---
NOTION_KR_MARKET_ANALYSIS_PAGE_ID=your_notion_page_id_here

# ===========================
# 해외 시장 (미국/글로벌)
# ===========================

# --- 암호화폐 거래소 (CCXT) ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
UPBIT_API_KEY=your_upbit_api_key_here
UPBIT_API_SECRET=your_upbit_api_secret_here
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# --- FRED 경제지표 API (https://fred.stlouisfed.org/) ---
FRED_API_KEY=your_fred_api_key_here

# --- 해외 시장 분석 ---
MARKET_ANALYSIS_ENABLED=true
MARKET_ANALYSIS_SYMBOLS=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA,AVGO,LLY,WMT

# --- 해외 노션 리포트 ---
NOTION_MARKET_ANALYSIS_PAGE_ID=your_notion_page_id_here

# ===========================
# Market Intelligence (공통)
# ===========================

# Finnhub 뉴스 API (미설정 시 Google News RSS 폴백)
FINNHUB_API_KEY=your_finnhub_api_key_here

# 기능 토글
FINBERT_ENABLED=false
NEWS_COLLECTION_ENABLED=true
NEWS_MAX_PER_SYMBOL=5
SIGNAL_TRACKING_ENABLED=true
EVENT_CALENDAR_ENABLED=true
FUNDAMENTALS_ENABLED=true
REFLECTION_ENABLED=true
SENTIMENT_SIZING_ENABLED=false

# 수급 데이터 (Supply/Demand Flow)
CBOE_PCR_ENABLED=true
KR_INVESTOR_FLOW_ENABLED=true

# ===========================
# LLM 서버
# ===========================

LLM_BASE_URL=http://your-llm-server-ip:8080
LLM_ENABLED=true
# LLM_SIGNAL_TIMEOUT=5
# LLM_REGIME_TIMEOUT=15
# LLM_SENTIMENT_TIMEOUT=30

# ===========================
# 알림 (Slack / Email)
# ===========================

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL=C0123456789

#SMTP_SERVER=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USERNAME=your_email@gmail.com
#SMTP_PASSWORD=your_app_password
#SMTP_FROM=your_email@gmail.com
#SMTP_TO=recipient@example.com

# ===========================
# Live Trading
# ===========================

LIVE_TRADING_ENABLED=false
# 'dry_run' logs orders without submitting; 'live' submits real orders
LIVE_TRADING_MODE=dry_run
LIVE_TRADING_MAX_DAILY_LOSS_PCT=0.05
LIVE_TRADING_MAX_DAILY_TRADES=50
LIVE_TRADING_MAX_POSITION_COUNT=10
# KIS_MOCK=true overrides at API level — all orders go to 모의투자 regardless of LIVE_TRADING_MODE

# ===========================
# Adaptive Trading (관제 모드)
# ===========================

# 레짐 기반 전략 자동 전환 (프리셋에서도 개별 설정 가능)
ADAPTIVE_REGIME_SWITCHING=false

# 변동성 기반 파라미터 자동 조정
ADAPTIVE_PARAMETERS=false

# 주간 자동 최적화 (매주 일요일 00:00 KST)
AUTO_OPTIMIZATION_ENABLED=false

# ===========================
# 대시보드 (Streamlit)
# ===========================

STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
STREAMLIT_SERVER_RUN_ON_SAVE=false
